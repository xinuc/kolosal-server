{
  "server": {
    "host": "127.0.0.1",
    "port": 3001,
    "workers": 2,
    "request_queue_size": 100,
    "max_request_size": 10485760,
    "request_timeout": 30,
    "keep_alive_timeout": 65,
    "shutdown_timeout": 30,
    "health_check_interval": 30
  },
  "security": {
    "enabled": false,
    "rate_limiter": {
      "enabled": false,
      "max_requests": 60,
      "window_size": 60
    },
    "cors": {
      "enabled": false,
      "allowed_origins": ["*"],
      "allowed_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allowed_headers": ["*"],
      "allow_credentials": false,
      "max_age": 86400
    },
    "api_key": {
      "enabled": false,
      "required": false,
      "header_name": "X-API-Key",
      "api_keys": []
    }
  },
  "default_model_settings": {
    "temperature": 0.7,
    "max_tokens": 2048,
    "top_p": 0.95,
    "top_k": 40,
    "repeat_penalty": 1.1,
    "seed": -1,
    "stop_sequences": []
  },
  "performance": {
    "cache_enabled": true,
    "cache_size": 100,
    "cache_ttl": 3600,
    "request_queue_size": 100,
    "max_concurrent_requests": 10,
    "batch_size": 4,
    "prefetch_count": 2
  },
  "logging": {
    "level": "info",
    "file": "",
    "max_file_size": 10485760,
    "max_files": 5,
    "console": true,
    "format": "text"
  },
  "database": {
    "qdrant": {
      "host": "localhost",
      "port": 6333,
      "grpc_port": 6334,
      "use_grpc": false,
      "collection_name": "documents",
      "api_key": "",
      "timeout": 30,
      "max_connections": 10,
      "connection_timeout": 5,
      "embedding_batch_size": 5,
      "default_embedding_model": "text-embedding-3-small"
    }
  },
  "inference_engines": [],
  "default_inference_engine": "llama-cpu"
}